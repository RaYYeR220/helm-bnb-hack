# CoinMarketCap Pro API key (https://pro.coinmarketcap.com) — free Basic tier works for daily OHLCV
CMC_API_KEY=your-cmc-pro-api-key

# --- On-chain agent layer (deliverable E3; requires the `agent` dep group) ---
# Password that encrypts/decrypts the Helm agent wallet keystore. NEVER commit
# this. The keystore lives under data_cache/keystore/ (gitignored). A fresh
# wallet is auto-generated + encrypted on first run; the private key never
# touches disk in plaintext and is never logged.
HELM_AGENT_WALLET_PASSWORD=choose-a-strong-password

# Directory for the encrypted Keystore V3 wallet file (default: data_cache/keystore).
# Must stay inside a gitignored path.
HELM_KEYSTORE_DIR=data_cache/keystore
